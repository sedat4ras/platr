{
  "expo": {
    "name": "Platr",
    "slug": "platr",
    "version": "1.0.0",
    "scheme": "platr",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sedataras.Platr",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Platr uses your location to tag where a plate was spotted.",
        "NSCameraUsageDescription": "Platr uses the camera to capture plate photos.",
        "NSPhotoLibraryUsageDescription": "Platr accesses your photo library to upload plate images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "package": "app.platr.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F1A",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}

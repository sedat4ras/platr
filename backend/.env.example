# Platr Backend — Environment variables
# Copy to .env and fill in your values

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://platr:platr@localhost:5432/platr

# App
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production

# VicRoads OSINT settings
REGO_CHECK_RATE_LIMIT_SECONDS=3.0
REGO_CHECK_TIMEOUT_SECONDS=15

# AI Moderation (Claude) — get key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
